# Env-var conventions
#   * Server-only vars carry no prefix and are read from `process.env` on the
#     server only. They must NEVER appear in client code, because nothing
#     strips them from the browser bundle.
#   * Client-safe vars use the `VITE_` prefix. Vite statically inlines these
#     into the browser bundle at build time. Treat them as public.
#
# Copy this file to `.env.local` and fill in the real values. `.env.local`
# is gitignored. See `docs/env.md` for details.

# ---- Supabase ---------------------------------------------------------------

# Bare project ref (e.g. `abcdefghijklmnop`). Used by the `supabase` CLI.
SUPABASE_PROJECT_REF=your-project-ref

# Server-only secret. Bypasses RLS — never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Connection string for migrations and direct server-side DB access.
# Local default points at the Compose stack from `docker/compose.yml`.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Client-safe Supabase config. The browser uses these via `createClient()`.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ---- External services (mocked by default in dev) ---------------------------

# When `true`, the GOC verification module returns canned responses instead of
# scraping `str.optical.org`. Local dev defaults to mocked so the regulator's
# website is never hit from a laptop.
GOC_MOCK=true
GOC_API_KEY=

# When `true`, the signup-to-paying-Practitioner flow skips Stripe entirely:
# `startCheckout` synthesises stripe IDs and flips the new Practitioner row
# straight to subscription_status=active. The /api/stripe/webhook handler is
# not exercised in mock mode. Local dev defaults to mocked so a laptop never
# needs Stripe API keys to run the signup flow end-to-end.
VITE_STRIPE_MOCK=true
VITE_STRIPE_PUBLISHABLE_KEY=

# Server-only Stripe secrets. Required once `VITE_STRIPE_MOCK=false`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# The Stripe Price id for the £29/month MiCare subscription. Created once in
# the Stripe dashboard (test mode) and committed here per environment.
STRIPE_PRICE_ID=

# Origin used to build Stripe Checkout success_url / cancel_url. No trailing
# slash. Local dev uses the Vite dev-server origin.
APP_URL=http://localhost:3000

# ---- Email (Resend) ---------------------------------------------------------

# Required for Notify-Me confirmations, notification emails, and monthly
# summary emails. Local dev can leave this blank — Inbucket on port 54324
# catches anything GoTrue sends.
RESEND_API_KEY=
